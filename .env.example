# Slack
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token
SLACK_SIGNING_SECRET=your-signing-secret

# Claude
ANTHROPIC_API_KEY=sk-ant-your-api-key

# Git — 프라이빗 레포 접근용 (Docker 환경 필수)
GITHUB_TOKEN=ghp_your-personal-access-token
# GIT_REPO_URL=https://github.com/your-org/your-repo
# GIT_BASE_CLONE_PATH=/tmp/oncall-bot-repo
# GIT_WORKTREE_BASE_PATH=/tmp/oncall-bot-worktrees
# GIT_DEFAULT_REF=develop

# Project (optional — 설정하면 워크트리 대신 이 경로 사용)
# SERVICE_PROJECT_PATH=/path/to/your/service/project

# Docker — Atlassian MCP 서버 소스 경로 (호스트 기준)
# ATLASSIAN_AGENT_DIR=/path/to/atlassian-mcp-server
# ATLASSIAN_MCP_REPO_URL=https://github.com/alton15/atlassian-mcp-server

# Optional
LOG_LEVEL=info
LOG_FORMAT=json
AGENT_MAX_RETRIES=2
MAX_CONCURRENT_REQUESTS=3
